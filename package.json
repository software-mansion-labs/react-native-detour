{
  "name": "react-native-detour-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm --filter @swmansion/react-native-detour prepare",
    "test": "pnpm --filter @swmansion/react-native-detour test",
    "typecheck": "pnpm --filter @swmansion/react-native-detour typecheck",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "release": "pnpm --filter @swmansion/react-native-detour release",
    "prebuild:all": "pnpm --filter './examples/*' prebuild",
    "examples:expo-bare": "pnpm --filter @swmansion/react-native-detour-expo-bare",
    "examples:react-navigation": "pnpm --filter @swmansion/react-native-detour-react-navigation",
    "examples:react-navigation-advanced": "pnpm --filter @swmansion/react-native-detour-react-navigation-advanced",
    "examples:expo-router": "pnpm --filter @swmansion/react-native-detour-expo-router",
    "examples:expo-router-native-intent": "pnpm --filter @swmansion/react-native-detour-expo-router-native-intent",
    "examples:expo-router-advanced": "pnpm --filter @swmansion/react-native-detour-expo-router-advanced"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native/eslint-config": "^0.78.0",
    "commitlint": "^19.6.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "pnpm": {
    "overrides": {
      "metro": "0.82.5",
      "metro-babel-transformer": "0.82.5",
      "metro-cache": "0.82.5",
      "metro-cache-key": "0.82.5",
      "metro-config": "0.82.5",
      "metro-core": "0.82.5",
      "metro-file-map": "0.82.5",
      "metro-minify-terser": "0.82.5",
      "metro-resolver": "0.82.5",
      "metro-runtime": "0.82.5",
      "metro-source-map": "0.82.5",
      "metro-symbolicate": "0.82.5",
      "metro-transform-plugins": "0.82.5",
      "metro-transform-worker": "0.82.5"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
