{
  "expo": {
    "name": "Detour Expo Router",
    "slug": "detour-expo-router",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/detour-logo.png",
    "scheme": "detour-expo-router",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "detourreactnative.exporouter",
      "supportsTablet": true,
      "icon": "./assets/detour-logo.png",
      "associatedDomains": ["applinks:<your-org>.godetour.link"]
    },
    "android": {
      "package": "detourreactnative.exporouter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/detour-logo.png",
        "backgroundColor": "#0C1221"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "<your-org>.godetour.link",
              "pathPrefix": "/<your-app-hash>"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C1221",
          "image": "./assets/detour-logo-transparent.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/detour-logo-transparent.png",
            "imageWidth": 120
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
