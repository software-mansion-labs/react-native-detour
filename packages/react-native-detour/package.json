{
  "name": "@swmansion/react-native-detour",
  "version": "2.1.0",
  "description": "sdk for handling deferred links",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./expo-router": {
      "react-native": "./src/expo-router/index.ts",
      "source": "./src/expo-router/index.ts",
      "types": "./lib/typescript/src/expo-router/index.d.ts",
      "default": "./lib/module/expo-router/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion-labs/react-native-detour.git"
  },
  "author": "swmansion <contact@godetour.com> (https://godetour.dev/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/software-mansion-labs/react-native-detour/issues"
  },
  "homepage": "https://github.com/software-mansion-labs/react-native-detour#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native/babel-preset": "0.83.4",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/jest": "^29.5.5",
    "@types/react": "~19.2.2",
    "del-cli": "^5.1.0",
    "expo-application": "*",
    "expo-clipboard": "*",
    "expo-constants": "~55.0.11",
    "expo-device": "~55.0.12",
    "expo-localization": "*",
    "jest": "^29.7.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "0.40.13",
    "release-it": "^17.10.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=2.0.0",
    "expo-application": ">=6.1.5",
    "expo-clipboard": ">=6.0.0",
    "expo-constants": ">=17.1.7",
    "expo-device": ">=7.0.0",
    "expo-localization": ">=15.0.0",
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/../../examples/",
      "<rootDir>/lib/"
    ]
  },
  "release-it": {
    "hooks": {
      "after:bump": "echo \"export const version = '${version}';\nexport const SDK_HEADER_VALUE = \\`react-native/\\${version}\\`;\" > src/version.ts"
    },
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "js",
    "type": "library",
    "version": "0.53.0"
  }
}
